{
  "name": "mikeyerke-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": ">=10 <11"
  },
  "scripts": {
    "predev": "npm run prepare:admin",
    "dev": "next dev",
    "prebuild": "npm run prepare:admin",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prepare:admin": "node scripts/prepare-admin-assets.mjs",
    "qa:content": "node scripts/check-content-quality.mjs",
    "test:smoke": "playwright test --project=smoke",
    "ci": "npm run qa:content && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.3",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.7",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "decap-cms": "^3.8.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.7.2"
  }
}
